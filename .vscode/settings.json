{
  // Disable VS Code's built-in CSS validation — it doesn't understand
  // Tailwind's custom at-rules (@tailwind, @apply, @layer, @screen, @variants).
  // The Tailwind CSS IntelliSense extension handles validation instead.
  "css.validate": false,
  "scss.validate": false,
  "less.validate": false,

  // Tell Tailwind IntelliSense where to find the config
  "tailwindCSS.experimental.classRegex": [],
  "tailwindCSS.includeLanguages": {
    "typescript": "javascript",
    "typescriptreact": "javascript"
  },

  // Recommended extensions for this project
  "extensions.recommendations": [
    "bradlc.vscode-tailwindcss",
    "esbenp.prettier-vscode",
    "dbaeumer.vscode-eslint"
  ]
}
