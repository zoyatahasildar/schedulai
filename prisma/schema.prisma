// ChronoAI - Prisma Schema
// This file is owned by the Lead (Auth module)
// All teammates use these models — DO NOT modify without notifying the team

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USER ──────────────────────────────────────────────
// Owned by: Lead (Auth module)
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  username      String?   @unique  // used for public booking link: /book/[username]
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  eventTypes    EventType[]
  availability  Availability[]

  @@map("users")
}

// ─── EVENT TYPE ────────────────────────────────────────
// Owned by: Lead (created here) + Member 2 (booking logic)
model EventType {
  id          String   @id @default(cuid())
  title       String
  description String?
  duration    Int      // in minutes e.g. 30, 60
  price       Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@map("event_types")
}

// ─── BOOKING ───────────────────────────────────────────
// Owned by: Member 2 (Booking Engine)
model Booking {
  id          String        @id @default(cuid())
  startTime   DateTime      // always stored in UTC
  endTime     DateTime      // always stored in UTC
  guestEmail  String
  guestName   String
  guestPhone  String?
  notes       String?
  status      BookingStatus @default(PENDING)
  meetingLink String?       // optional video call link
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  eventTypeId String
  eventType   EventType @relation(fields: [eventTypeId], references: [id], onDelete: Restrict)

  @@index([startTime, endTime])
  @@map("bookings")
}

// ─── AVAILABILITY ──────────────────────────────────────
// Owned by: Member 3 (Calendar module)
model Availability {
  id        String   @id @default(cuid())
  dayOfWeek Int      // 0=Sunday, 1=Monday, ... 6=Saturday
  startTime String   // "09:00" format (UTC)
  endTime   String   // "17:00" format (UTC)
  isActive  Boolean  @default(true)

  // Relations
  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dayOfWeek])
  @@map("availability")
}

// ─── NEXTAUTH MODELS ───────────────────────────────────
// Required by NextAuth — DO NOT modify
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── ENUMS ─────────────────────────────────────────────
enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
